import json

FILE = "tasks.json"

def load_tasks():
    try:
        with open(FILE, "r") as f:
            return json.load(f)
    except:
        return []

def save_tasks(tasks):
    with open(FILE, "w") as f:
        json.dump(tasks, f, indent=4)

def add_task(tasks):
    task = input("Enter task: ")
    tasks.append({"task": task, "done": False})
    save_tasks(tasks)

def view_tasks(tasks):
    for i, t in enumerate(tasks):
        status = "✔" if t["done"] else "✘"
        print(f"{i+1}. {t['task']} [{status}]")

def mark_done(tasks):
    view_tasks(tasks)
    i = int(input("Task number: ")) - 1
    if 0 <= i < len(tasks):
        tasks[i]["done"] = True
        save_tasks(tasks)

def delete_task(tasks):
    view_tasks(tasks)
    i = int(input("Task number: ")) - 1
    if 0 <= i < len(tasks):
        tasks.pop(i)
        save_tasks(tasks)

def main():
    tasks = load_tasks()
    while True:
        print("\n1.Add 2.View 3.Done 4.Delete 5.Exit")
        ch = input("Choice: ")

        if ch == "1": add_task(tasks)
        elif ch == "2": view_tasks(tasks)
        elif ch == "3": mark_done(tasks)
        elif ch == "4": delete_task(tasks)
        elif ch == "5": break

main()
