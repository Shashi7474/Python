"""
DP vs Greedy
DP → considers all possibilities
Greedy → chooses best at each step
"""

# Greedy (Coin change - not always optimal)
def greedy_coin(coins, amount):
    coins.sort(reverse=True)
    count = 0
    for coin in coins:
        while amount >= coin:
            amount -= coin
            count += 1
    return count


# DP (Optimal solution)
def dp_coin(coins, amount):
    dp = [float('inf')] * (amount + 1)
    dp[0] = 0

    for i in range(1, amount + 1):
        for coin in coins:
            if coin <= i:
                dp[i] = min(dp[i], dp[i - coin] + 1)

    return dp[amount]


if __name__ == "__main__":
    coins = [1, 3, 4]
    amount = 6

    print("Greedy:", greedy_coin(coins, amount))
    print("DP:", dp_coin(coins, amount))
