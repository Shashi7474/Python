products = {}

def add_product():
    name = input("Enter product name: ")
    old_price = float(input("Enter old price: "))
    new_price = float(input("Enter new price: "))
    
    products[name] = {
        "old": old_price,
        "new": new_price,
        "diff": new_price - old_price
    }

def analyze_prices():
    for name, data in products.items():
        diff = data["diff"]
        
        if diff > 0:
            print(f"{name}: Price Increased by {diff}")
        elif diff < 0:
            print(f"{name}: Price Dropped by {-diff}")
        else:
            print(f"{name}: No Change")

while True:
    print("\n1.Add Product 2.Analyze 3.Exit")
    ch = int(input("Enter choice: "))

    if ch == 1:
        add_product()
    elif ch == 2:
        analyze_prices()
    elif ch == 3:
        break
