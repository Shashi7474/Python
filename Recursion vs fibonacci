"""
Recursion vs Dynamic Programming
Recursion → repeated calculations
DP → stores results (memoization)
"""

# Recursion
def fib_rec(n):
    if n <= 1:
        return n
    return fib_rec(n-1) + fib_rec(n-2)

# DP
def fib_dp(n):
    dp = [0]*(n+1)
    if n > 0:
        dp[1] = 1
    for i in range(2, n+1):
        dp[i] = dp[i-1] + dp[i-2]
    return dp[n]

print("Rec:", fib_rec(6))
print("DP:", fib_dp(6))
