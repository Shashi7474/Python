# Array (Python List)
arr = [10, 20, 30]
print("Array access:", arr[1])  # O(1)


# Linked List
class Node:
    def __init__(self, data):
        self.data = data
        self.next = None

# Create linked list
head = Node(10)
head.next = Node(20)
head.next.next = Node(30)

# Traverse
temp = head
print("Linked List:", end=" ")
while temp:
    print(temp.data, end=" ")
    temp = temp.next
