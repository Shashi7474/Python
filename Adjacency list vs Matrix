"""
Adjacency List vs Matrix
List → space efficient
Matrix → fast lookup
"""

# Adjacency List
graph_list = {
    0: [1, 2],
    1: [2],
    2: [0]
}

print("Adjacency List:", graph_list)


# Adjacency Matrix
graph_matrix = [
    [0,1,1],
    [0,0,1],
    [1,0,0]
]

print("Adjacency Matrix:")
for row in graph_matrix:
    print(row)
